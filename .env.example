# Copy this file to .env and fill in your values before running docker compose

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_DB=HotelManagementDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ──────────────────────────────────────────────
# JWT — secret must be at least 32 characters
# ──────────────────────────────────────────────
JWT_SECRET=change_me_at_least_32_chars_long_secret_key_here
JWT_ISSUER=HotelManagementAPI
JWT_AUDIENCE=HotelManagementClient
JWT_EXPIRY_MINUTES=60

# ──────────────────────────────────────────────
# Ports (change if these are taken on your server)
# ──────────────────────────────────────────────
BACKEND_PORT=5001
FRONTEND_PORT=3000

# ──────────────────────────────────────────────
# URLs — replace with your server's IP or domain
# FRONTEND_URL  → allowed CORS origin for the backend
# NEXT_PUBLIC_API_URL → where the browser sends API requests
# ──────────────────────────────────────────────
FRONTEND_URL=http://your-server-ip:3000
NEXT_PUBLIC_API_URL=http://your-server-ip:5001/api
